# === API Keys ===

# LLM provider (any OpenAI-compatible API — Kimi 2.5, OpenAI, etc.)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-k2.5

# Pexels (free — sign up at https://pexels.com)
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay (optional, free — sign up at https://pixabay.com/api/docs/)
# Adds extra stock footage/image sources beyond Pexels
# PIXABAY_API_KEY=your_pixabay_api_key_here

# TTS Provider — choose one: "elevenlabs" or "fish_audio"
TTS_PROVIDER=fish_audio

# ElevenLabs (sign up at https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Fish Audio (pay-as-you-go at ~$0.10/video — sign up at https://fish.audio)
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here
# FISH_AUDIO_VOICE_ID=optional_voice_model_id
# FISH_AUDIO_MODEL=speech-1.5

# === Output Settings ===
OUTPUT_RESOLUTION=1920x1080
OUTPUT_FPS=30

# === FFmpeg (optional) ===
# Only needed if auto-detection hangs. Leave blank to auto-detect.
# Windows: FFMPEG_PATH=C:\ProgramData\chocolatey\bin\ffmpeg.exe
# macOS:   FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# === YouTube Publishing & Analytics (optional) ===
# To enable uploads, scheduling, metrics, and the autonomous agent:
#   1. Go to https://console.cloud.google.com
#   2. Create a project and enable BOTH APIs:
#      - "YouTube Data API v3" (uploads, comments, video metadata)
#      - "YouTube Analytics API" (deep metrics: retention, CTR, impressions)
#   3. Create OAuth 2.0 credentials (Desktop application type)
#   4. Download the JSON and save as client_secrets.json in the project root
#   5. Required OAuth scopes (included automatically):
#      - youtube.upload — publish videos
#      - youtube.force-ssl — read/update/delete videos and comments
#      - yt-analytics.readonly — read YouTube Analytics reports
# The first publish will open a browser to authorize your YouTube channel.
# Per-channel tokens are saved at channels/<id>/youtube_token.json.
# If you manage multiple channels, each authenticates separately on first use.
