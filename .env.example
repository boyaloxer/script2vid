# === API Keys ===

# LLM provider (any OpenAI-compatible API — Kimi 2.5, OpenAI, etc.)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.moonshot.ai/v1
LLM_MODEL=kimi-k2.5

# Pexels (free — sign up at https://pexels.com)
PEXELS_API_KEY=your_pexels_api_key_here

# ElevenLabs (free tier — sign up at https://elevenlabs.io)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# === Output Settings ===
OUTPUT_RESOLUTION=1920x1080
OUTPUT_FPS=30

# === FFmpeg (optional) ===
# Only needed if auto-detection hangs. Leave blank to auto-detect.
# Windows: FFMPEG_PATH=C:\ProgramData\chocolatey\bin\ffmpeg.exe
# macOS:   FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# === YouTube Publishing (optional) ===
# To enable --publish and --schedule flags:
#   1. Go to https://console.cloud.google.com
#   2. Create a project and enable "YouTube Data API v3"
#   3. Create OAuth 2.0 credentials (Desktop application type)
#   4. Download the JSON and save as client_secrets.json in the project root
# The first publish will open a browser to authorize your YouTube channel.
# After that, a youtube_token.json is saved so you won't need to re-authorize.
